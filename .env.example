# ═══════════════════════════════════════════════════════════════════
#  waha-mcp-server — Environment Variables
#  Copy this to .env for local dev. Set these in Railway → Variables
#  for production. ALL three starred vars are REQUIRED.
# ═══════════════════════════════════════════════════════════════════

# ── MCP Server ──────────────────────────────────────────────────────
# Port Railway exposes (Railway injects this automatically — don't change)
PORT=8080

# * REQUIRED — agents send this in the x-api-key header to use the MCP
# Generate: openssl rand -hex 32
MCP_API_KEY=REPLACE_WITH_STRONG_SECRET

# ── WAHA (WhatsApp HTTP API) ─────────────────────────────────────────
# * REQUIRED — base URL of your WAHA service
#
#   Railway (same project, private networking):
#     http://waha.railway.internal:3000
#
#   Local dev (WAHA running via Docker):
#     http://localhost:3000
#
WAHA_BASE_URL=http://waha.railway.internal:3000

# * REQUIRED — must exactly match WHATSAPP_API_KEY set on the WAHA service
# This is what WAHA uses to protect its own REST API.
# If these don't match you'll get 401 errors from every tool call.
# Generate: openssl rand -hex 32
WAHA_API_KEY=REPLACE_WITH_SAME_VALUE_AS_WAHA_WHATSAPP_API_KEY

# ── Optional ─────────────────────────────────────────────────────────
# WhatsApp session name to auto-start on boot (default: "default")
# WAHA_DEFAULT_SESSION=default
