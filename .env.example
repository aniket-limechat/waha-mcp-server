# ── MCP Server ─────────────────────────────────────────────────────────────
PORT=8080

# API key agents must send in x-api-key header to use the MCP endpoint
# Generate with: openssl rand -hex 32
MCP_API_KEY=change-me-to-a-strong-secret

# ── WAHA (WhatsApp HTTP API) ────────────────────────────────────────────────
# Internal Railway URL when both services are in the same project:
#   http://waha.railway.internal:3000
# Local dev:
#   http://localhost:3000
WAHA_BASE_URL=http://localhost:3000

# API key set on your WAHA service (WHATSAPP_API_KEY env var)
WAHA_API_KEY=your-waha-api-key
