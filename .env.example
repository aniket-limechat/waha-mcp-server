# ═══════════════════════════════════════════════════════════════════
#  waha-mcp-server — Environment Variables
#
#  When deploying via docker-compose.yml (Railway):
#    Set ONLY these 2 variables in Railway → Service → Variables.
#    Everything else (WAHA_BASE_URL, WHATSAPP_API_KEY) is wired
#    up automatically by docker-compose.yml.
#
#  For local dev: copy to .env and fill in values.
# ═══════════════════════════════════════════════════════════════════

# * REQUIRED — agents send this in the x-api-key header to use the MCP
# Generate: openssl rand -hex 32
MCP_API_KEY=REPLACE_WITH_STRONG_SECRET

# * REQUIRED — shared secret between the MCP server and WAHA
# docker-compose passes this to WAHA as WHATSAPP_API_KEY automatically.
# Generate: openssl rand -hex 32
WAHA_API_KEY=REPLACE_WITH_STRONG_SECRET

# ── Set automatically by docker-compose (do NOT set in Railway) ──────
# WAHA_BASE_URL=http://waha:3000

# ── Local dev only (override if WAHA runs elsewhere) ─────────────────
# WAHA_BASE_URL=http://localhost:3000
# WAHA_DEFAULT_SESSION=default
# PORT=8080
