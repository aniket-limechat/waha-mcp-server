# ═══════════════════════════════════════════════════════════════════
#  waha-mcp-server — Environment Variables
#
#  Single-container deploy (Railway): set ONLY these 2 variables.
#  WAHA_BASE_URL and WHATSAPP_API_KEY are handled automatically
#  by start.sh — you do NOT need to set them.
# ═══════════════════════════════════════════════════════════════════

# * REQUIRED — agents send this in the x-api-key header to call the MCP
# Generate: openssl rand -hex 32
MCP_API_KEY=REPLACE_WITH_STRONG_SECRET

# * REQUIRED — shared secret used by both the MCP server (to call WAHA)
# and WAHA itself (as WHATSAPP_API_KEY). start.sh bridges them automatically.
# Generate: openssl rand -hex 32
WAHA_API_KEY=REPLACE_WITH_STRONG_SECRET

# ── Set automatically by start.sh — do NOT set in Railway ────────────
# WAHA_BASE_URL=http://localhost:3000
# WHATSAPP_API_KEY=$WAHA_API_KEY

# ── Optional ──────────────────────────────────────────────────────────
# PORT=8080                     (Railway injects this)
# WAHA_DEFAULT_SESSION=default
